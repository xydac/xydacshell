# xydacshell — modern profile zshrc.
# shellcheck shell=bash
# Starship prompt · plain zsh (no oh-my-zsh) · graceful fallbacks for optional tools.
#
# Do not edit this file directly.
# For customizations, edit: ~/.xydacshell/zshrc.custom

: ${XYDACSHELL_HOME:=$HOME/.xydacshell}

# History: sane defaults.
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_VERIFY INC_APPEND_HISTORY

# Better completions.
autoload -Uz compinit && compinit -C
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'
setopt AUTO_CD INTERACTIVE_COMMENTS PROMPT_SUBST

bindkey -e

# Prefix-matching history navigation with Up/Down.
# Type `ssh` then Up → cycles past commands starting with `ssh`.
# Ports oh-my-zsh's default behavior without needing OMZ.
autoload -Uz up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search

# Bind both the standard (^[[A/B) and application-mode (^[OA/B) escape
# sequences — terminals like iTerm2 / Terminal.app / Ghostty send different
# codes depending on their "application cursor keys" setting.
for _k in '^[[A' '^[OA'; do bindkey "$_k" up-line-or-beginning-search;   done
for _k in '^[[B' '^[OB'; do bindkey "$_k" down-line-or-beginning-search; done
bindkey '^P' up-line-or-beginning-search     # Ctrl-P
bindkey '^N' down-line-or-beginning-search   # Ctrl-N
unset _k

# Right-arrow / End accept the current autosuggestion ghost text.
bindkey '^[[C' forward-char
bindkey '^[OC' forward-char

# Tell zsh-autosuggestions that our custom history widgets should clear the
# ghost text when invoked (otherwise the suggestion can stick as you cycle).
typeset -ga ZSH_AUTOSUGGEST_CLEAR_WIDGETS
ZSH_AUTOSUGGEST_CLEAR_WIDGETS+=(up-line-or-beginning-search down-line-or-beginning-search)

# Helpers — mirror classic for compat with user customizations that use them.
commandexists(){ type "$1" &> /dev/null; }

# zsh-autosuggestions: ghost-text completion from history. Accept with → or ^E.
# Sourced from the submodule we share with classic.
if [ -f "$XYDACSHELL_HOME/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
  source "$XYDACSHELL_HOME/zsh-autosuggestions/zsh-autosuggestions.zsh"
  ZSH_AUTOSUGGEST_STRATEGY=(history completion)
  ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=242'
fi

# zsh-syntax-highlighting. MUST be sourced after autosuggestions and
# near the end of the file; this is the plugin's own recommendation.
if [ -f "$XYDACSHELL_HOME/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
  source "$XYDACSHELL_HOME/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi

# Prompt: starship when available, a quiet fallback when not.
if commandexists starship; then
  eval "$(starship init zsh)"
else
  PROMPT='%F{cyan}%n%f %F{blue}%~%f %# '
fi

# Modern CLI tools — used when available.
if commandexists zoxide; then
  eval "$(zoxide init zsh)"
  alias cd=z 2>/dev/null || true
fi
if commandexists lsd; then
  alias ls='lsd --group-dirs=first'
  alias ll='lsd -l --group-dirs=first --git --date=relative'
  alias la='lsd -la --group-dirs=first --git --date=relative'
  alias lt='lsd -l --group-dirs=first --git --date=relative --sort=time'
  alias tree='lsd --tree'
fi
if commandexists bat; then
  alias cat='bat --paging=never'
elif commandexists batcat; then
  # Debian/Ubuntu ship bat as `batcat` to avoid a name clash with another tool.
  alias bat='batcat'
  alias cat='batcat --paging=never'
fi
if commandexists fzf; then
  # Load key-bindings and completion from either brew or apt layouts.
  for p in \
    /opt/homebrew/opt/fzf/shell \
    /usr/local/opt/fzf/shell \
    /usr/share/fzf \
    /usr/share/doc/fzf/examples; do
    [ -f "$p/key-bindings.zsh" ]   && source "$p/key-bindings.zsh"
    [ -f "$p/completion.zsh" ]     && source "$p/completion.zsh"
  done
fi

# Aliases (carry forward the useful ones from classic).
alias c=clear
alias gitlog="git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"

# Editor.
if commandexists nvim; then
  export EDITOR=nvim
  alias vim=nvim
fi

# nnn helper, preserved.
if commandexists nnn; then
  alias n=nnn
  export NNN_USE_EDITOR=1
fi
